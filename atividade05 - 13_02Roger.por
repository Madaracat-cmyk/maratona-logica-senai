programa {
  funcao inicio() {
    inteiro n1 , n2

    escreva("\nQual foi a quantidade do setor A" )
    leia(n1)
    escreva("\nQual foi a quantidade do setor B" )
    leia(n2)
    escreva("\nSetor A ====",  n1)
    escreva("\nSetor B ====",  n2)
     se (n1 > n2){
      escreva("\nO  setor A fez mais do que setor B")
     } senao{
      escreva("\nO setor B fez mais do que setor A")
     }
  }
}
