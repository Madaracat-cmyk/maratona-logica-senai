programa {
  funcao inicio() {
    inteiro producaoPorHora
		inteiro hora
		inteiro producaoTotal
    escreva("Digite a quantidade produzida por hora: ")
		leia(producaoPorHora)
    para (hora = 1; hora <= 10; hora++){

    }
    producaoTotal = hora * producaoPorHora
    escreva("    ", hora, " hora(s) ", producaoTotal, "\n")
  }
}
